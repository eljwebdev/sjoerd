---
import { loadQuery } from "../sanity/lib/load-query";
import Layout from "../layouts/Layout.astro";
import PageBuilder from "../components/PageBuilder.astro";

const { data: settings } = await loadQuery<{
  settings: {
    homepage?: {
      _ref: string;
    };
  };
}>({
  query: `*[_type == "settings"][0]{ settings }`,
});

const homepageRef = settings?.settings?.homepage?._ref;

const { data: page } = homepageRef
  ? await loadQuery<{
      title: string;
      metaTitle?: string;
      metaDescription?: string;
      keywords?: string;
      content: any[];
    }>({
      query: `*[_type == "page" && _id == $id][0]{
        ...,
        content[]{
          ...,
          _type == "faqs" => {
            ...,
            faqs[]->
          },
          _type == "formBlock" => {
            ...,
            form->
          }
        }
      }`,
      params: { id: homepageRef },
    })
  : { data: null };
---

<Layout
  title={page?.metaTitle || page?.title}
  description={page?.metaDescription}
  keywords={page?.keywords}
>

<section>
  <div class="container--grid container--margin-normal">
    <div class="big-text">
      <p>
        typ
      </p>
      <p>
        a brand defined by behaviour, built to attract the right minds
      </p>
    </div>
    
    <div class="small-text" style="margin-top: 40px;">
      <p>
        Brand identity, 
      </p>
      <p>
        web design, motion,
      </p>
      <p>
        interaction design
      </p>
    </div>
    
    <div class="small-text lowercase" style="margin-top: 40px;">
      <p>
        Brand identity, 
      </p>
      <p>
        web design, motion,
      </p>
      <p>
        interaction design
      </p>
    </div>
    
    <div class="small-text uppercase" style="margin-top: 40px;">
      <p>
        Brand identity, 
      </p>
      <p>
        web design, motion,
      </p>
      <p>
        interaction design
      </p>
    </div>
  
  </div>

</section>

</Layout>
