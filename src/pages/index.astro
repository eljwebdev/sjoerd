---
import Layout from "../layouts/Layout.astro";
import { sanityClient } from 'sanity:client';
import Project from "../components/blocks/Project.astro";

const homePage = await sanityClient.fetch(
  `*[_type == "homePage"][0]{
    title, 
    description, 
    work[]{
      imagesDesktop[]{
        _type,
        _type == "imageBlock" => {
          myRangeField,
          image{
            asset->{
              ...,
              metadata{
                dimensions{ width, height, aspectRatio }
              }
            },
            hotspot,
            crop
          },
          alt,
          caption
        },
        _type == "videoBlock" => {
          myRangeField,
          video{ asset->{ url } },
          videoFallback{ asset->{ url } },
          posterImage{
            asset->{
              ...,
              metadata{
                dimensions{ width, height, aspectRatio }
              }
            },
            hotspot,
            crop
          },
          description,
          hasAudio
        }
      },
      imagesMobile[]{
        _type,
        _type == "imageBlock" => {
          myRangeField,
          image{
            asset->{
              ...,
              metadata{
                dimensions{ width, height, aspectRatio }
              }
            },
            hotspot,
            crop
          },
          alt,
          caption
        },
        _type == "videoBlock" => {
          myRangeField,
          video{ asset->{ url } },
          videoFallback{ asset->{ url } },
          posterImage{
            asset->{
              ...,
              metadata{
                dimensions{ width, height, aspectRatio }
              }
            },
            hotspot,
            crop
          },
          description,
          hasAudio
        }
      },
      title,
      subtitle,
      textEntries[]{
        label,
        content
      },
      imageHeight,
      textPosition
    }
  }`
);
const { title, description, work } = homePage ?? {};

---



<Layout pageTitle={title} pageDescription={description}>

{work?.map((project) => (
  <Project
    imagesDesktop={project.imagesDesktop}
    imagesMobile={project.imagesMobile}
    title={project.title}
    subtitle={project.subtitle}
    textEntries={project.textEntries}
    imageHeight={project.imageHeight}
    textPosition={project.textPosition}
  />
))}


</Layout>
