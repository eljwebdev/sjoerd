---
import type { SanityDocument } from "@sanity/client";
import { loadQuery, PAGE_QUERY } from "../sanity/lib/load-query";
import Layout from "../layouts/Layout.astro";
import PageBuilder from "../components/PageBuilder.astro";

export const prerender = true;

export async function getStaticPaths() {
  const { data: pages } = await loadQuery<SanityDocument[]>({
    query: `*[_type == "page"]`,
  });

  const { data: settings } = await loadQuery<{
    settings: { homepage?: { _ref: string } };
  }>({
    query: `*[_type == "settings"][0]{ settings }`,
  });

  const homepageId = settings?.settings?.homepage?._ref;

  return pages
    .filter((page) => page._id !== homepageId)
    .map(({ slug }) => ({
      params: { slug: slug.current },
    }));
}

const { params } = Astro;

const { data: page } = await loadQuery<{
  title: string;
  metaTitle?: string;
  metaDescription?: string;
  keywords?: string;
  content: any[];
}>({
  query: PAGE_QUERY,
  params,
});
---

<Layout
  title={page?.metaTitle || page?.title || "Page"}
  description={page?.metaDescription}
  keywords={page?.keywords}
>
  {page?.content ? <PageBuilder content={page.content} /> : null}
</Layout>
