---
import Layout from "../layouts/Layout.astro";
import Search from "astro-pagefind/components/Search";
---

<Layout title="Search">
    <h1 class="search-heading">Search</h1>
    <Search id="search" className="search-widget" uiTranslations={{ placeholder: "Search..." }} />
</Layout>

<style lang="scss">
  .search-page {
    max-width: 800px;
    margin-inline: auto;
    padding: 3rem var(--padding-horizontal);
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .search-heading {
    font-size: 2rem;
    font-weight: 700;
  }

  .search-widget {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: var(--rood);
    --pagefind-ui-text: var(--zwart);
    --pagefind-ui-background: var(--wit);
    --pagefind-ui-border: var(--grijs-licht);
    --pagefind-ui-border-radius: 4px;
  }
</style>
