---
interface FooterLink {
  label: string;
  linkType: 'internal' | 'external';
  internalLink?: {
    _id: string;
    _type: string;
    slug?: { current: string };
  };
  externalUrl?: string;
  target?: string;
  rel?: string;
}

interface SocialItem {
  platform: string;
  label?: string;
  url: string;
}

interface Props {
  logoUrl?: string;
  siteTitle: string;
  copyright?: string;
  links: FooterLink[];
  legalLinks: FooterLink[];
  socials: SocialItem[];
  homepageId?: string;
}

const { logoUrl, siteTitle, copyright, links = [], legalLinks = [], socials = [], homepageId } = Astro.props;

const platformNames: Record<string, string> = {
  facebook: 'Facebook',
  instagram: 'Instagram',
  x: 'X (Twitter)',
  linkedin: 'LinkedIn',
  youtube: 'YouTube',
  tiktok: 'TikTok',
  pinterest: 'Pinterest',
  github: 'GitHub',
  other: 'Anders',
};

function resolveHref(link: FooterLink): string {
  if (link.linkType === 'external') {
    return link.externalUrl ?? '#';
  }
  const ref = link.internalLink;
  if (!ref?.slug?.current) return '/';
  if (homepageId && ref._id === homepageId) return '/';
  switch (ref._type) {
    case 'page': return `/${ref.slug.current}`;
    case 'post': return `/post/${ref.slug.current}`;
    default: return `/${ref.slug.current}`;
  }
}
---

<footer class="site-footer">
  {logoUrl && (
    <a href="/" class="footer-logo">
      <img src={logoUrl} alt={siteTitle} class="footer-logo-img" />
    </a>
  )}

  {links.length > 0 && (
    <ul class="footer-links">
      {links.map((link) => (
        <li>
          <a
            href={resolveHref(link)}
            target={link.target ?? undefined}
            rel={link.rel ?? undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  )}

  {socials.length > 0 && (
    <ul class="footer-socials">
      {socials.map((social) => (
        <li>
          <a href={social.url} target="_blank" rel="noopener noreferrer">
            {social.label || platformNames[social.platform] || social.platform}
          </a>
        </li>
      ))}
    </ul>
  )}

  {legalLinks.length > 0 && (
    <ul class="footer-legal">
      {legalLinks.map((link) => (
        <li>
          <a
            href={resolveHref(link)}
            target={link.target ?? undefined}
            rel={link.rel ?? undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  )}

  <div class="footer-bottom">
    {copyright && <p class="footer-copyright">© {new Date().getFullYear()} {copyright}</p>}
  </div>
</footer>

<style>
  .site-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 2rem;
    border-top: 1px solid #e5e5e5;
    margin-top: auto;
  }

  .footer-logo {
    display: block;
    height: 5rem;
  }

  .footer-logo-img {
    height: 100%;
    width: auto;
  }

  .footer-links,
  .footer-socials,
  .footer-legal {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-links a,
  .footer-socials a {
    text-decoration: none;
    color: inherit;
    font-size: 0.875rem;
  }

  .footer-links a:hover,
  .footer-socials a:hover,
  .footer-legal a:hover {
    text-decoration: underline;
  }

  .footer-legal a {
    text-decoration: none;
    color: #666;
    font-size: 0.8125rem;
  }

  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1.5rem;
    justify-content: center;
  }

  .footer-copyright {
    margin: 0;
    font-size: 0.8125rem;
    color: #666;
  }

  .footer-credit {
    font-size: 0.8125rem;
    color: #666;
    text-decoration: none;
  }

  .footer-credit:hover {
    text-decoration: underline;
  }
</style>
