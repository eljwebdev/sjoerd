---
interface FormOption {
  _key: string;
  label: string;
  value: string;
}

interface FormField {
  _key: string;
  fieldType: string;
  label: string;
  name: { current: string };
  placeholder?: string;
  required?: boolean;
  width?: "full" | "half";
  options?: FormOption[];
}

interface OnSubmit {
  onSubmitAction?: "message" | "redirect";
  successMessage?: string;
  redirectPage?: { slug?: { current?: string } };
  enableDataLayer?: boolean;
  dataLayerEvent?: string;
}

interface FormData {
  _id: string;
  title: string;
  formsparkAction: string;
  submitLabel?: string;
  onSubmit?: OnSubmit;
  fields?: FormField[];
}

interface Props {
  title?: string;
  form?: FormData;
}

const { title, form } = Astro.props;
const formElId = `form-${form?._id ?? "unknown"}`;
const sanityFormId = form?._id ?? "";
const successMessage = form?.onSubmit?.successMessage ?? "Bedankt voor je bericht!";
const enableDataLayer = form?.onSubmit?.enableDataLayer ?? false;
const dataLayerEvent = form?.onSubmit?.dataLayerEvent ?? "form_submission";
const formTitle = form?.title ?? "";
---

{form?.formsparkAction && form?.fields && (
  <section class="form-section">
    {title && <h2>{title}</h2>}

    <form
      id={formElId}
      method="POST"
      class="form-grid"
    >
      {form.fields.map((field) => {
        const name = field.name?.current ?? field._key;
        const width = field.width ?? "full";
        const required = field.required ?? false;

        return (
          <div class={`form-field form-field--${width}`} data-type={field.fieldType}>
            {field.fieldType === "hidden" ? (
              <input type="hidden" name={name} />
            ) : field.fieldType === "textarea" ? (
              <label>
                <span class="form-label">{field.label}{required && <span class="required"> *</span>}</span>
                <textarea
                  name={name}
                  placeholder={field.placeholder}
                  required={required}
                  rows={4}
                />
              </label>
            ) : field.fieldType === "select" ? (
              <label>
                <span class="form-label">{field.label}{required && <span class="required"> *</span>}</span>
                <select name={name} required={required}>
                  <option value="">Selecteer...</option>
                  {field.options?.map((opt) => (
                    <option value={opt.value}>{opt.label}</option>
                  ))}
                </select>
              </label>
            ) : field.fieldType === "radio" ? (
              <fieldset>
                <legend class="form-label">{field.label}{required && <span class="required"> *</span>}</legend>
                <div class="option-group">
                  {field.options?.map((opt) => (
                    <label class="option-label">
                      <input type="radio" name={name} value={opt.value} required={required} />
                      <span>{opt.label}</span>
                    </label>
                  ))}
                </div>
              </fieldset>
            ) : field.fieldType === "checkbox" ? (
              <fieldset>
                <legend class="form-label">{field.label}{required && <span class="required"> *</span>}</legend>
                <div class="option-group">
                  {field.options?.map((opt) => (
                    <label class="option-label">
                      <input type="checkbox" name={name} value={opt.value} />
                      <span>{opt.label}</span>
                    </label>
                  ))}
                </div>
              </fieldset>
            ) : (
              <label>
                <span class="form-label">{field.label}{required && <span class="required"> *</span>}</span>
                <input
                  type={field.fieldType as astroHTML.JSX.HTMLInputTypeAttribute}
                  name={name}
                  placeholder={field.placeholder}
                  required={required}
                />
              </label>
            )}
          </div>
        );
      })}

      <div class="form-field form-field--full">
        <button type="submit">{form.submitLabel ?? "Verzenden"}</button>
      </div>
    </form>

    <div id={`${formElId}-success`} class="form-success" hidden>
      <p>{successMessage}</p>
    </div>

    <div id={`${formElId}-error`} class="form-error" hidden>
      <p>Er ging iets mis. Probeer het opnieuw.</p>
    </div>

    <script is:inline define:vars={{ formElId, sanityFormId, enableDataLayer, dataLayerEvent, formTitle }}>
      document.getElementById(formElId)?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const form = e.target;
        const button = form.querySelector('button[type="submit"]');
        const originalText = button.textContent;
        const errorEl = document.getElementById(formElId + "-error");
        errorEl.hidden = true;
        button.disabled = true;
        button.textContent = "Verzenden...";

        try {
          const formData = new FormData(form);
          const data = {};
          formData.forEach((value, key) => {
            if (data[key]) {
              data[key] = [].concat(data[key], value);
            } else {
              data[key] = value;
            }
          });

          const res = await fetch("/api/form-submit", {
            method: "POST",
            body: JSON.stringify({ formId: sanityFormId, data }),
            headers: {
              "Content-Type": "application/json",
              Accept: "application/json",
            },
          });

          const result = await res.json();

          if (result.success) {
            if (enableDataLayer) {
              window.dataLayer = window.dataLayer || [];
              window.dataLayer.push({
                event: dataLayerEvent || "form_submission",
                formId: sanityFormId,
                formTitle: formTitle,
                ...data,
              });
            }

            if (result.action === "redirect" && result.redirectUrl) {
              window.location.href = result.redirectUrl;
            } else {
              form.style.display = "none";
              const successEl = document.getElementById(formElId + "-success");
              if (result.message) {
                successEl.querySelector("p").textContent = result.message;
              }
              successEl.hidden = false;
            }
          } else {
            form.reset();
            button.disabled = false;
            button.textContent = originalText;
            errorEl.hidden = false;
          }
        } catch {
          form.reset();
          button.disabled = false;
          button.textContent = originalText;
          errorEl.hidden = false;
        }
      });
    </script>
  </section>
)}

<style lang="scss">
  .form-section {
    max-width: 48rem;
    margin: 0 auto;
    padding: 4rem 1rem;
  }

  h2 {
    font-size: clamp(1.25rem, 3vw, 2rem);
    font-weight: 600;
    color: rgb(30 41 59);
    margin-bottom: 2rem;
    text-align: center;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form-field--full {
    grid-column: 1 / -1;
  }

  label,
  fieldset {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    border: none;
    padding: 0;
    margin: 0;
  }

  .form-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: rgb(51 65 85);
  }

  .required {
    color: rgb(239 68 68);
  }

  input[type="text"],
  input[type="email"],
  input[type="tel"],
  input[type="number"],
  textarea,
  select {
    width: 100%;
    padding: 0.625rem 0.75rem;
    border: 1px solid rgb(203 213 225);
    border-radius: 0.375rem;
    font-size: 1rem;
    font-family: inherit;
    background: white;
    color: rgb(15 23 42);
    transition: border-color 0.15s;
    box-sizing: border-box;
  }

  input:focus,
  textarea:focus,
  select:focus {
    outline: none;
    border-color: rgb(59 130 246);
    box-shadow: 0 0 0 3px rgb(59 130 246 / 0.1);
  }

  textarea {
    resize: vertical;
  }

  .option-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  .option-label {
    flex-direction: row;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    color: rgb(51 65 85);
    cursor: pointer;
  }

  .option-label input {
    width: auto;
  }

  button[type="submit"] {
    width: 100%;
    padding: 0.75rem 1.5rem;
    background: rgb(30 41 59);
    color: white;
    border: none;
    border-radius: 0.375rem;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.15s;
  }

  button[type="submit"]:hover {
    background: rgb(51 65 85);
  }

  button[type="submit"]:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .form-success {
    text-align: center;
    padding: 2rem;
    background: rgb(240 253 244);
    border: 1px solid rgb(187 247 208);
    border-radius: 0.5rem;
  }

  .form-success p {
    color: rgb(22 101 52);
    font-size: 1.125rem;
    margin: 0;
  }

  .form-error {
    text-align: center;
    padding: 2rem;
    background: rgb(254 242 242);
    border: 1px solid rgb(252 165 165);
    border-radius: 0.5rem;
    margin-top: 1.25rem;
  }

  .form-error p {
    color: rgb(153 27 27);
    font-size: 1.125rem;
    margin: 0;
  }

  @media (max-width: 640px) {
    .form-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
