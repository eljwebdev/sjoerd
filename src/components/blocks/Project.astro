---
import SanityImage from "../SanityImage.astro";
import PortableText from "../../components/PortableText.astro";
import "swiper/css";


const {
  imagesDesktop,
  imagesMobile,
  title,
  subtitle,
  textEntries,
  imageHeight = "setting-height-normal",
  textPosition = "setting-text-below",
} = Astro.props;
---

<section class="section-project">
  <div class={`section-project-inner ${textPosition}`}>
    <div class={`images-desktop ${imageHeight}`}>
        <div class="images-desktop-inner"> 
            {imagesDesktop?.map((item: any) => (
                <div class="image-wrapper">
                    <SanityImage image={item.image} alt={item.alt} />
                </div>

            ))}
        </div>
    </div>
    <div class="images-mobile container--margin-normal">
      {imagesMobile?.map((item: any) => (
        <SanityImage image={item.image} alt={item.alt} />
      ))}
    </div>
    <div class="texts-container">
        <div class="titles">
            <div class="titles-inner">
                {title && <h2>{title}</h2>}
                {subtitle && <p class="subtitle c-dim">{subtitle}</p>}
            </div>
            <div class="show-button-container">
                <button class="show-button"><span class="lowercase">View all</span></button>
            </div>
        </div>
        <div class="info">
            <ul class="text-entry">
                {textEntries?.map((entry: any) => (
                    <li>
                    {entry.label && <span class="label small-text uppercase">{entry.label}</span>}
                    {entry.content && <PortableText value={entry.content} />}
                    </li>
                ))}
            </ul>
        </div>
        <div class="numbers">
            <p>1 / 9</p>
        </div>
    </div>
  </div>
</section>

<style lang="scss">

    .images-mobile {
        @include responsiveMin($md){
            display: none;
        }
        @include responsive($md){
            display: flex;
            flex-direction: column;
            gap: 12px;  
            max-height: 500px;
            overflow: hidden;
            transition: max-height 0.6s ease;
            :global(.image) {
                width: 100%;
            }
            &.expanded {
                max-height: 500vh;
            }
        }
    }

    .images-desktop {
        overflow: hidden;
        margin-left: var(--padding-horizontal);
        @include responsive($md){
            display: none;
        }
        .images-desktop-inner {
            display: flex;
            // gap: 12px;
        }
        &.settings-height-normal {
            :global(.image-wrapper) {
                height: clamp(500px, 30.36vw + 246.8px, 1024px);
                min-width: calc((100vw - (2 * var(--padding-horizontal))));
                width: calc((100vw - (2 * var(--padding-horizontal))));
                overflow: hidden;
            }
            :global(.image-wrapper.small){
                aspect-ratio: 1 / 8;
            }
            :global(.image-wrapper.medium){
                aspect-ratio: 1 / 8;
            }
            :global(.image-wrapper.large){
                aspect-ratio: 1 / 8;
            }
            :global(.image) {
                height: 100%;
                width: 100%;
                object-fit: cover;
            }
        }
    }


    .texts-container {
        @include responsive($md){
            display: flex;
            flex-direction: column;
        }

        .titles {
            @include responsive($md){
                order: 1;
                display: flex;
                justify-content: space-between;
                padding-top: 24px;
            }
            
            .titles-inner {
                @include responsive($md){
                    max-width: 70%;
                }
            }
            .show-button-container {
                display: none;

                @include responsive($md){
                    display: block;
                    .show-button {
                        display: flex;
                        padding-right: 10px;
                        span {
                            text-decoration: underline;
                            text-underline-offset: 3px;
                            text-decoration-thickness: 1px;
                        }
                        &::after {
                            content: "↓";
                            display: block;
                            margin-left: 5px;
                            transition: all 0.3s ease;
                        }
                        &.expanded {
                            &::after {
                                transform: rotate(180deg);
                            }
                        }
                    }
                }
            }
        }

        .info {
            @include responsive($md){
                order: 0;
                max-height: 1px;
                overflow: hidden;
                transition: max-height 0.4s ease;

                &.expanded {
                    max-height: 100vh;
                }
            }
            .text-entry {
                display: flex;
                flex-direction: column;
                gap: 12px;
                padding-bottom: 32px;
                padding-top: 32px;
                margin-top: 12px;
                
                @include responsive($md){
                
                }
                li {
                    display: grid;
                    grid-template-columns: repeat(12, 1fr);
                    gap: 12px;
                    @include responsive($md){
                
                    }
                    span {
                        grid-column: 1 / 3;
                        @include responsive($md){
                    
                        }
                    }
                    :global(.portable-text-container) {
                        grid-column: 3 / 10;
                        @include responsive($md){
                    
                        }
                    }
                }
            }
        }
        .numbers {
            display: block;
            @include responsive($md){
                display: none;
            }
        }
    }

    .section-project-inner.settings-text-below {
        .texts-container {
            @include responsiveMin($md){
                display: grid;
                grid-template-columns: repeat(12, 1fr);
                gap: 16px;
            }

            @include responsiveMin(1440px) {
                gap: 32px;
            }
            .titles {
                grid-column: 1 / 4;
            }
            .info {
                grid-column: 9 / 12;    
            }
            .numbers {
                grid-column: 12 / 13;
                justify-self: end;
            }
        }
    }

    .section-project-inner.settings-text-left {
        @include responsiveMin($md){
            display: grid;
            grid-template-columns: repeat(12, 1fr);
            gap: 16px;
        }

        @include responsiveMin(1440px) {
            gap: 32px;
        }
        .images-desktop {
            grid-column: 1 / 8;
        }
        .texts-container {
            grid-column: 8 / 13;
        }
    }

    .section-project-inner.settings-text-right {
        @include responsiveMin($md){
            display: grid;
            grid-template-columns: repeat(12, 1fr);
            gap: 16px;
        }

        @include responsiveMin(1440px) {
            gap: 32px;
        }
        .images-desktop {
            grid-column: 8 / 13;
        }
        .texts-container {
            grid-column: 1 / 8;
        }
    }

</style>

<script>
    // @ts-nocheck
    // import Swiper from "swiper";
    // import { FreeMode } from "swiper/modules";

    document.addEventListener("astro:page-load", () => {
        const sections = document.querySelectorAll('.section-project');
        sections.forEach(section => {
            // const swiperEl = section.querySelector('.swiper');
            // if (swiperEl) {
            //     new Swiper(swiperEl, {
            //         modules: [FreeMode],
            //         freeMode: true,
            //         slidesPerView: "1.2",
            //         grabCursor: true,
            //         momentum: true,
            //         momentumRatio: 3,
            //         mousewheel: {
            //             enabled: true,

            //         },
            //         scrollbar: {
            //             el: '.swiper-scrollbar',
            //             draggable: true,
            //         },
            //     });
            // }
        });

        const showButtons = document.querySelectorAll('.show-button');
        showButtons.forEach(button => {
            button.addEventListener('click', () => {
                const parent = button.closest('.section-project-inner');
                const imagesMobile = parent.querySelector('.images-mobile');
                const textDiv = parent.querySelector('.right');
                const buttonText = button.querySelector('span');
                if (imagesMobile.classList.contains('expanded') && textDiv.classList.contains('expanded') && button.classList.contains('expanded')) {
                    imagesMobile.classList.remove('expanded');
                    textDiv.classList.remove('expanded');
                    button.classList.remove('expanded');
                    buttonText.innerText = "View all";
                } else {
                    imagesMobile.classList.add('expanded');
                    textDiv.classList.add('expanded');
                    button.classList.add('expanded');
                    buttonText.innerText = "View less";
                }
            });
        });
    });


</script>