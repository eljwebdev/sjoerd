---
import SanityImage from "../SanityImage.astro";
import PortableText from "../../components/PortableText.astro";
import "swiper/css";


const {
  imagesDesktop,
  imagesMobile,
  title,
  subtitle,
  textEntries,
  imageHeight = "setting-height-normal",
  textPosition = "setting-text-below",
} = Astro.props;

---

<section class="section-project">

  <div class={`section-project-inner ${textPosition}`}>

    <div class={`images-desktop ${imageHeight}`}>
        <div class="images-desktop-inner"> 
            {imagesDesktop?.map((item: any) => (
                <div class="image-wrapper">
                    <SanityImage image={item.image} alt={item.alt} />
                </div>

            ))}
        </div>
    </div>

    <div class="images-mobile container--margin-normal">
      {imagesMobile?.map((item: any) => (
        <SanityImage image={item.image} alt={item.alt} />
      ))}
    </div>

    <div class="texts-container">
        <div class="titles">
            <div class="titles-inner">
                {title && <h2>{title}</h2>}
                {subtitle && <p class="subtitle c-dim">{subtitle}</p>}
            </div>
            <div class="show-button-container">
                <button class="show-button"><span class="lowercase">View all</span></button>
            </div>
        </div>
        <div class="info">
            <ul class="text-entry">
                {textEntries?.map((entry: any) => (
                    <li>
                    {entry.label && <span class="label small-text uppercase">{entry.label}</span>}
                    {entry.content && <PortableText value={entry.content} />}
                    </li>
                ))}
            </ul>
        </div>
        <div class="numbers">
            <p><span id="current-index">1</span><span class="c-dim">—</span><span class="c-dim"id="total-count">9</span></p>
        </div>
    </div>
  </div>
</section>

<style lang="scss">

    /* DEFAULTS FOR ALL LAYOUTS */

    .images-mobile {
        @include responsiveMin($md){
            display: none;
        }
        @include responsive($md){
            display: flex;
            flex-direction: column;
            gap: 12px;  
            max-height: 500px;
            overflow: hidden;
            transition: max-height 0.6s ease;
            :global(.image) {
                width: 100%;
            }
            &.expanded {
                max-height: 500vh;
            }
        }
    }

    .images-desktop {
        overflow-y: hidden;
        overflow-x: scroll;
        @include responsive($md){
            display: none;
        }
        :global(.image-wrapper) {
            height: clamp(500px, 30.36vw + 246.8px, 1024px);
            overflow: hidden;
            @include responsiveMin($md){
                min-width: calc( ((100vw - (2 * var(--padding-horizontal)) - (11 * 16px) )  / 12) * 8 + (7 * 16px) );
            }
            @include responsiveMin($xl){
                min-width: calc( ((100vw - (2 * var(--padding-horizontal)) - (11 * 32px) )  / 12) * 8 + (7 * 32px) );
            }
        }

        // :global(.image-wrapper.small){
        //     min-width: calc( ((100vw - (2 * var(--padding-horizontal)) - (11 * 32px) )  / 12) * 3 + (4 * 32px) );
        // }
        // :global(.image-wrapper.medium){
        //     min-width: calc( ((100vw - (2 * var(--padding-horizontal)) - (11 * 32px) )  / 12) * 6 + (5 * 32px) );
        // }


        :global(.image) {
            height: 100%;
            width: 100%;
            object-fit: cover;
        }
        &.settings-height-small {
            :global(.image-wrapper) {
                height: clamp(500px, 18.2vw + 348px, 814px);            
            }
        }
        .images-desktop-inner {
            display: flex;
            gap: 16px;
            @include responsiveMin($xl) {
                gap: 32px;
            }
        }
    }

    .texts-container {
        @include responsive($md){
            display: flex;
            flex-direction: column;
            padding-left: var(--padding-horizontal);
            padding-right: var(--padding-horizontal);
        }
        @include responsiveMin($md){
            padding-top: 32px;
        }

        .titles {
            @include responsive($md){
                order: 1;
                display: flex;
                justify-content: space-between;
                padding-top: 24px;
            }
            
            .titles-inner {
                @include responsive($md){
                    max-width: 70%;
                }
            }
            .show-button-container {
                display: none;

                @include responsive($md){
                    display: block;
                    .show-button {
                        display: flex;
                        span {
                            text-decoration: underline;
                            text-underline-offset: 3px;
                            text-decoration-thickness: 1px;
                        }
                        &::after {
                            content: "↓";
                            display: block;
                            margin-left: 5px;
                            transition: all 0.3s ease;
                        }
                        &.expanded {
                            &::after {
                                transform: rotate(180deg);
                            }
                        }
                    }
                }
            }
        }

        .info {
            @include responsive($md){
                order: 0;
                max-height: 1px;
                overflow: hidden;
                transition: max-height 0.4s ease;

                &.expanded {
                    max-height: 100vh;
                }
            }
            .text-entry {
                display: flex;
                flex-direction: column;
                gap: 14px;
                
                @include responsive($md){
                    gap: 12px;
                    padding-bottom: 32px;
                    padding-top: 32px;
                    margin-top: 12px;
                }
                li {
                    display: grid;
                    grid-template-columns: repeat(12, 1fr);
                    gap: 0px;
                    @include responsive($md){
                
                    }
                    span {
                        grid-column: 1 / 4;                    
                        @include responsive($md){
                            grid-column: 1 / 3;                    
                        }
                    }
                    :global(.portable-text-container) {
                        grid-column: 4 / 13;
                        @include responsive($md){
                            grid-column: 3 / 10;
                        }
                    }
                }
            }
        }
        .numbers {
            display: block;
            @include responsive($md){
                display: none;
            }
        }
    }

    /* LAYOUT: TEXT BELOW */
    .section-project-inner.settings-text-below {
        .images-desktop {
            @include responsiveMin($md){
                padding-left: var(--padding-horizontal);
            }
        }
        .texts-container {
            @include responsiveMin($md){
                padding-left: var(--padding-horizontal);
                padding-right: var(--padding-horizontal);
                display: grid;
                grid-template-columns: repeat(12, 1fr);
                gap: 16px;
                .titles {
                    grid-column: 1 / 4;
                }
                .info {
                    grid-column: 9 / 12;    
                }
                .numbers {
                    grid-column: 12 / 13;
                    justify-self: end;
                }
            }
            @include responsiveMin($xl) {
                gap: 32px;
            }
        }
    }

    /* Mixin for default side text styling with 3 cols above $xl */
    @mixin textscontainerSide {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        grid-auto-flow: dense;
        gap: 16px;
        .titles {
            grid-column: 1 / 3;
            grid-row: 1;
            align-self: end;
        }
        .info {
            grid-column: 1 / 3;
            grid-row: 2;
            align-self: start;
        }
        .numbers {
            grid-column: 3 / 4;
            grid-row: 1;
            align-self: end;
            justify-self: end;
        }
    }

    /* LAYOUT: TEXT LEFT */
    .section-project-inner.settings-text-left {

        .images-desktop {
            @include responsiveMin($md){
                padding-left: var(--padding-horizontal);
            }
            @include responsiveMin($xl){
                padding-left: 0;
            }
        }

        /* On inbetween md and xl, on all settings text goes below */
        .texts-container {
            @include responsiveMin($md){
                padding-left: var(--padding-horizontal);
                padding-right: var(--padding-horizontal);
                display: grid;
                grid-template-columns: repeat(12, 1fr);
                gap: 16px;
                .titles {
                    grid-column: 1 / 4;
                }
                .info {
                    grid-column: 9 / 12;    
                }
                .numbers {
                    grid-column: 12 / 13;
                    justify-self: end;
                }
            }
            @include responsiveMin($xl) {
                gap: 32px;
            }
        }
        /* Above xl, text on the left side */
        @include responsiveMin($xl){
            display: grid;
            grid-template-columns: repeat(12, 1fr);
            grid-auto-flow: dense;
            gap: 32px;
            .images-desktop {
                grid-column: 4 / 13;
            }
            .texts-container {
                @include textscontainerSide();
                grid-column: 1 / 4;
                padding-left: var(--padding-horizontal);
                padding-right: 0;
            }
        }
    }

    /* LAYOUT: TEXT RIGHT */
    .section-project-inner.settings-text-right {

        .images-desktop {
            @include responsiveMin($md){
                padding-left: var(--padding-horizontal);
            }
            @include responsiveMin($xl){
                padding-left: 0;
            }
        }

        /* On inbetween md and xl, on all settings text goes below */
        .texts-container {
            @include responsiveMin($md){
                padding-left: var(--padding-horizontal);
                padding-right: var(--padding-horizontal);
                display: grid;
                grid-template-columns: repeat(12, 1fr);
                gap: 16px;
                .titles {
                    grid-column: 1 / 4;
                }
                .info {
                    grid-column: 9 / 12;    
                }
                .numbers {
                    grid-column: 12 / 13;
                    justify-self: end;
                }
            }
            @include responsiveMin($xl) {
                gap: 32px;
            }
        }

        /* Above xl, text on the right side */
        @include responsiveMin($xl){
            padding-right: var(--padding-horizontal);
            display: grid;
            grid-template-columns: repeat(12, 1fr);
            grid-auto-flow: dense;
            gap: 32px;

            .images-desktop {
                // padding-left: var(--padding-horizontal);
                grid-column: 1 / 10;
            }
            
            .texts-container {
                @include textscontainerSide();
                grid-column: 10 / 13;
                gap: 32px;
                padding-right: var(--padding-horizontal);
                padding-left: 0;
            }
        }
    }

</style>

<script>
    // @ts-nocheck
    // import Swiper from "swiper";
    // import { FreeMode } from "swiper/modules";

    document.addEventListener("astro:page-load", () => {

        const sections = document.querySelectorAll('.section-project');
        sections.forEach(section => {
            // const swiperEl = section.querySelector('.swiper');
            // if (swiperEl) {
            //     new Swiper(swiperEl, {
            //         modules: [FreeMode],
            //         freeMode: true,
            //         slidesPerView: "1.2",
            //         grabCursor: true,
            //         momentum: true,
            //         momentumRatio: 3,
            //         mousewheel: {
            //             enabled: true,

            //         },
            //         scrollbar: {
            //             el: '.swiper-scrollbar',
            //             draggable: true,
            //         },
            //     });
            // }
        });

        const showButtons = document.querySelectorAll('.show-button');
        showButtons.forEach(button => {
            button.addEventListener('click', () => {
                const parent = button.closest('.section-project-inner');
                const imagesMobile = parent.querySelector('.images-mobile');
                const textDiv = parent.querySelector('.info');
                const buttonText = button.querySelector('span');
                if (imagesMobile.classList.contains('expanded') && textDiv.classList.contains('expanded') && button.classList.contains('expanded')) {
                    imagesMobile.classList.remove('expanded');
                    textDiv.classList.remove('expanded');
                    button.classList.remove('expanded');
                    buttonText.innerText = "View all";
                } else {
                    imagesMobile.classList.add('expanded');
                    textDiv.classList.add('expanded');
                    button.classList.add('expanded');
                    buttonText.innerText = "View less";
                }
            });
        });

        function syncNumbersHeight() {
            if (window.innerWidth <= 835) return;
            document.querySelectorAll('.section-project-inner.settings-text-left, .section-project-inner.settings-text-right').forEach(inner => {
                const titles = inner.querySelector('.titles');
                const numbers = inner.querySelector('.numbers');
                if (titles && numbers) {
                    numbers.style.height = titles.offsetHeight + 'px';
                }
            });
        }
        syncNumbersHeight();
        window.addEventListener('resize', syncNumbersHeight);

    });



</script>