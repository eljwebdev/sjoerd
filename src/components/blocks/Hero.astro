---
import PortableText from "../PortableText.astro";
import SanityImage from "../SanityImage.astro";

interface Props {
  title?: string;
  text?: any[];
  image?: any;
}

const { title, text, image } = Astro.props;
---

<section class="hero">
  <div class="hero-content">
    {title && <h1 class="hero-title">{title}</h1>}
    {text && (
      <div class="hero-text">
        <PortableText portableText={text} />
      </div>
    )}
  </div>
  <div class="hero-overlay"></div>
  {image && (
    <SanityImage
      image={image}
      alt={title || ""}
      width={1600}
      height={800}
      layout="fullWidth"
      priority={true}
      class="hero-image"
    />
  )}
</section>

<style lang="scss" is:global>
  .hero {
    position: relative;
    isolation: isolate;
    width: 100%;
    aspect-ratio: 2 / 1;
    padding: 4rem 1rem;
    overflow: hidden;
  }

  .hero-content {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    height: 100%;
    z-index: 20;
  }

  .hero-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: white;
    text-align: center;
    max-width: 48rem;
  }

  @media (min-width: 768px) {
    .hero-title { font-size: 2.25rem; }
  }

  @media (min-width: 1024px) {
    .hero-title { font-size: 3.75rem; }
  }

  .hero-text {
    display: flex;
    align-items: center;
    color: white;
    line-height: 1.7;
    max-width: 65ch;
  }

  .hero-text p { color: white; }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background-color: #737373;
    opacity: 0.5;
    z-index: 10;
  }

  .hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(4px);
  }
</style>
