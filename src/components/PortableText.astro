---
import { PortableText as PortableTextInternal } from 'astro-portabletext'

const { value } = Astro.props

/* filter out empty blocks to prevent rendering empty <p> tags */
const filtered = value?.filter((block: any) => {
  if (block._type !== 'block') return true
  return block.children?.some((child: any) => child.text?.trim() !== '')
})
---

<div class="portable-text-container">
  <PortableTextInternal value={filtered} />
</div>