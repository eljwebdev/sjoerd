---

<section class="error-page">
  <span class="error-code">500</span>
  <h1>Interne serverfout</h1>
  <p>Er is iets misgegaan. Probeer het later opnieuw.</p>
  <a href="/" class="error-link">Terug naar home</a>
</section>

<style>
  .error-page {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 4rem 1rem;
    min-height: 50vh;
  }

  .error-code {
    font-size: 6rem;
    font-weight: 800;
    line-height: 1;
    opacity: 0.15;
  }

  h1 {
    margin-top: 0.5rem;
    font-size: 1.5rem;
  }

  p {
    margin-top: 0.5rem;
    color: rgb(100 116 139);
  }

  .error-link {
    margin-top: 1.5rem;
    padding: 0.625rem 1.25rem;
    border: 1px solid currentColor;
    border-radius: 0.375rem;
    text-decoration: none;
    color: inherit;
    transition: background-color 0.15s, color 0.15s;
  }

  .error-link:hover {
    background-color: #000;
    color: #fff;
  }
</style>
