---
import { urlFor } from '../sanity/lib/image'

interface Props {
  video?: { asset?: { url?: string } }
  videoFallback: { asset?: { url?: string } }
  posterImage: any
  description: string
  hasAudio?: boolean
}

const { video, videoFallback, posterImage, description, hasAudio = false } = Astro.props

const webmUrl = video?.asset?.url
const mp4Url = videoFallback?.asset?.url
const posterUrl = urlFor(posterImage).auto('format').url()
---

<div class="video-wrapper">
  <video
    class="video lozad-video"
    aria-label={description}
    poster={posterUrl}
    playsinline
    autoplay
    muted
    loop
  >
    {webmUrl && <source src={webmUrl} type="video/webm" />}
    <source src={mp4Url} type="video/mp4" />
  </video>
  {hasAudio && (
    <button class="video-unmute" aria-label="Unmute video">
      unmute
    </button>
  )}
</div>

<script>
    // @ts-nocheck
    import lozad from 'lozad';

    const observer = lozad('.lozad-video', {
        rootMargin: '100px 100px',
        loaded: (el) => {
            console.log('Video loaded:', el);
        }
    });
    observer.observe();

</script>

{hasAudio && (
  <script>
    document.querySelectorAll('.video-wrapper').forEach((wrapper) => {
      const video = wrapper.querySelector('video');
      const btn = wrapper.querySelector('.video-unmute');
      if (!video || !btn) return;

      btn.addEventListener('click', () => {
        video.muted = !video.muted;
        btn.textContent = video.muted ? 'unmute' : 'mute';
        btn.setAttribute('aria-label', video.muted ? 'Unmute video' : 'Mute video');
      });
    })
  </script>
)}

<style>
  .video-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .video-wrapper video {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .video-unmute {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    background: rgba(0, 0, 0, 0.5);
    color: #fff;
    border: none;
    padding: 0.4rem 0.8rem;
    cursor: pointer;
    font-size: 0.875rem;
  }
</style>
